#!/usr/bin/env bash 

set -euo pipefail
# My current most modern script for hpc use but it uses sequential execution

cd /scratch/user/s4802880/mlip_phonons

module purge
module load miniforge/25.3.0-3 # fix this version as needed
source "$ROOTMINIFORGE/etc/profile.d/conda.sh"

export XDG_CACHE_HOME="/scratch/user/$USER/.cache"
export HF_HOME="/scratch/user/$USER/huggingface"
export TORCH_HOME="/scratch/user/$USER/torch"
mkdir -p "$XDG_CACHE_HOME" "$HF_HOME" "$TORCH_HOME"

models_file="$(mktemp)"

python - <<'PY' > "$models_file"
import yaml
with open('config.yml') as f:
    data = yaml.safe_load(f)
for name, cfg in data.get("models", {}).items():
    env = cfg.get("environment")
    if not env:
        raise SystemExit(f"Missing environment for {name}")
    print(f"{name}\t{env}")
PY

while IFS=$'\t' read -r model env; do
  echo "Running $model in $env"
  conda activate "$env"
  mlip-phonons "$model"
  conda deactivate
done < "$models_file"

rm -f "$models_file"
